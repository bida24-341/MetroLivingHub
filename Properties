<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Real Estate Company</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <!-- Navigation Bar -->
    <header>
        <nav>
            <div class="logo">RealEstatePro</div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#properties">Properties</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content">
            <h1>Find Your Dream Home</h1>
            <p>Explore beautiful properties that match your lifestyle.</p>
            <a href="#properties" class="cta-button">Browse Properties</a>
        </div>
    </section>

    <!-- Properties Section -->
    <section id="properties" class="properties">
        <h2>Featured Properties</h2>
        <div class="property-cards">
            <div class="card">
                <img src="house1.jpg" alt="Property 1">
                <h3>Modern Villa</h3>
                <p>3 Bedrooms | 2 Bathrooms</p>
                <p class="price">$500,000</p>
            </div>
            <div class="card">
                <img src="house2.jpg" alt="Property 2">
                <h3>Luxury Apartment</h3>
                <p>2 Bedrooms | 2 Bathrooms</p>
                <p class="price">$350,000</p>
            </div>
            <div class="card">
                <img src="house3.jpg" alt="Property 3">
                <h3>Cozy Cottage</h3>
                <p>2 Bedrooms | 1 Bathroom</p>
                <p class="price">$200,000</p>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <h2>Contact Us</h2>
        <p>Get in touch with our agents for more details on available properties.</p>
        <form>
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea placeholder="Message" required></textarea>
            <button type="submit">Send Message</button>
        </form>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2025 RealEstatePro. All rights reserved.</p>
    </footer>
</body>
</html>
